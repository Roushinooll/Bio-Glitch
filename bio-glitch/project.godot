; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Bio Glitch"
run/main_scene="uid://cqf3dtdcdhard"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Axolote": "res://dialogs/characters/Axolote.dch",
"Player": "res://dialogs/characters/Player.dch",
"SERVA": "res://dialogs/characters/SERVA.dch"
}
directories/dtl_directory={
"dialogoInicial_PlayerPeixe": "res://dialogs/timelines/dialogoInicial_PlayerPeixe.dtl",
"level1_intro": "res://dialogs/timelines/level1_intro.dtl",
"serva_alerta_glitch": "res://dialogs/timelines/serva_alerta_glitch.dtl",
"serva_alerta_posGlitch": "res://dialogs/timelines/serva_alerta_posGlitch.dtl"
}
layout/style_directory={
"": "res://dialogs/styles/Default_style.tres",
"Default_style": "res://dialogs/styles/Default_style.tres"
}
layout/style_list=["res://dialogs/styles/Default_style.tres"]
layout/default_style="res://dialogs/styles/Default_style.tres"
glossary/default_case_sensitive=true

[display]

window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"compress/rdo_quality_loss": 0.0,
"compress/uastc_level": 0,
"detect_3d/compress_to": 1,
"mipmaps/generate": false,
"mipmaps/limit": -1,
"process/channel_remap/alpha": 3,
"process/channel_remap/blue": 2,
"process/channel_remap/green": 1,
"process/channel_remap/red": 0,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}

